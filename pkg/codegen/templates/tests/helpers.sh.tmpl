#!/usr/bin/env bash
# Shared test helpers for {{.Name}} CLI smoke tests.
# Source this file from individual test scripts:
#   SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
#   source "$SCRIPT_DIR/helpers.sh"

PASS=0
FAIL=0
RESULTS=()

# ---------------------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------------------

resolve_bin() {
  BIN="${1:-./{{.Name}}}"
  if [[ ! -x "$BIN" ]]; then
    echo "Binary not found: $BIN"
    echo "Run 'make build' first."
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Live-test gate
# ---------------------------------------------------------------------------

skip_live() {
  [[ "{{printf "${%s_LIVE_TESTS:-0}" .EnvPrefix}}" != "1" ]]
}

skip_admin() {
  [[ "{{printf "${%s_ADMIN_TESTS:-0}" .EnvPrefix}}" != "1" ]]
}

# ---------------------------------------------------------------------------
# Unique naming
# ---------------------------------------------------------------------------

unique_id() {
  date +%s
}

# ---------------------------------------------------------------------------
# Assertions
# ---------------------------------------------------------------------------

assert() {
  local name="$1"
  shift
  if "$@" >/dev/null 2>&1; then
    RESULTS+=("PASS  $name")
    ((PASS++))
  else
    RESULTS+=("FAIL  $name")
    ((FAIL++))
  fi
}

assert_fail() {
  local name="$1"
  shift
  if "$@" >/dev/null 2>&1; then
    RESULTS+=("FAIL  $name")
    ((FAIL++))
  else
    RESULTS+=("PASS  $name")
    ((PASS++))
  fi
}

assert_output_contains() {
  local name="$1"
  local pattern="$2"
  shift 2
  local out
  out=$("$@" 2>&1) || true
  if echo "$out" | grep -qF -- "$pattern"; then
    RESULTS+=("PASS  $name")
    ((PASS++))
  else
    RESULTS+=("FAIL  $name  (expected '$pattern' in output)")
    ((FAIL++))
  fi
}

assert_output_not_contains() {
  local name="$1"
  local pattern="$2"
  shift 2
  local out
  out=$("$@" 2>&1) || true
  if echo "$out" | grep -qF -- "$pattern"; then
    RESULTS+=("FAIL  $name  (unexpected '$pattern' in output)")
    ((FAIL++))
  else
    RESULTS+=("PASS  $name")
    ((PASS++))
  fi
}

# ---------------------------------------------------------------------------
# Report
# ---------------------------------------------------------------------------

print_report() {
  echo ""
  echo "=============================="
  echo "  Test Report"
  echo "=============================="
  for r in "${RESULTS[@]}"; do
    echo "  $r"
  done
  echo "------------------------------"
  echo "  Total: $((PASS + FAIL))  Pass: $PASS  Fail: $FAIL"
  echo "=============================="

  if [[ $FAIL -gt 0 ]]; then
    exit 1
  fi
}
